[user]
	name = 1-pluto1
	email = pluto.123452022@outlook.com
[http]
	postBuffer = 524288000
	lowSpeedLimit = 0
	lowSpeedTime = 999999
	proxy = http://127.0.0.1:6494
[core]
	compression = 0
[https]
	proxy = http://127.0.0.1:6494
[pager]
  diff = delta
  log = delta
  reflog = delta
  show = delta

[delta]
  navigate = true
  side-by-side = false
  line-numbers = true
  hyperlinks = true

[interactive]
  diffFilter = delta --color-only

[merge]
  conflictstyle = diff3
